{
    "name": "rocont/laravel-blade-debugbar",
    "description": "Laravel Debugbar tab that shows variables passed to Blade views",
    "keywords": ["laravel", "debugbar", "blade", "debug", "variables"],
    "license": "MIT",
    "type": "library",
    "require": {
        "php": "^8.0",
        "illuminate/support": "^9.0|^10.0|^11.0|^12.0",
        "illuminate/view": "^9.0|^10.0|^11.0|^12.0",
        "barryvdh/laravel-debugbar": "^3.7"
    },
    "require-dev": {
        "orchestra/testbench": "^7.0|^8.0|^9.0|^10.0"
    },
    "autoload": {
        "psr-4": {
            "Rocont\\BladeDebugbar\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Rocont\\BladeDebugbar\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Rocont\\BladeDebugbar\\BladeDebugbarServiceProvider"
            ]
        }
    },
    "scripts": {
        "test": "phpunit"
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}